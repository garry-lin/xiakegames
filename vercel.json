{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/play", "destination": "/play.html" },
    { "source": "/guide", "destination": "/guide.html" },
    { "source": "/how-to-play", "destination": "/how-to-play.html" },
    { "source": "/tips", "destination": "/tips.html" },
    { "source": "/classroom-games", "destination": "/classroom-games.html" },
    { "source": "/more-games", "destination": "/more-games.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/parents", "destination": "/parents.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" }
  ]
}
